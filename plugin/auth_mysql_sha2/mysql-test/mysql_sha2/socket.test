source init.inc;

connect con1, localhost,test1,pwd,,,,SOCKET NOSSL;
call checkme();
disconnect con1;
connect con2, localhost,test1,pwd,,,,SOCKET NOSSL;
call checkme();
disconnect con2;
replace_result $MASTER_MYSOCK MASTER_MYSOCK $MASTER_MYPORT MASTER_MYPORT;
error ER_ACCESS_DENIED_ERROR;
connect con3, localhost,test1,wrong_pwd,,,,SOCKET NOSSL;
connect con4, localhost,test2,,,,,SOCKET NOSSL;
call checkme();
disconnect con4;
replace_result $MASTER_MYSOCK MASTER_MYSOCK $MASTER_MYPORT MASTER_MYPORT;
error ER_ACCESS_DENIED_ERROR;
connect con5, localhost,test2 pwd,,,,,SOCKET NOSSL;

connection default;

source fini.inc;
