--source include/have_debug.inc

--echo #
--echo # MDEV-20034 Add support for the pre-defined weak SYS_REFCURSOR
--echo #

DELIMITER $$;
CREATE PROCEDURE p1()
BEGIN
  DECLARE c SYS_REFCURSOR;
  DECLARE a, b INT;
  OPEN c FOR SELECT 1, 2;
  FETCH c INTO a, b;
  CLOSE c;
END;
$$
DELIMITER ;$$

SHOW PROCEDURE CODE p1;
DROP PROCEDURE p1;


DELIMITER $$;
CREATE PACKAGE pkg
  PROCEDURE p1();
END;
$$
CREATE PACKAGE BODY pkg
  DECLARE a, b INT;
  PROCEDURE p1()
  BEGIN
    DECLARE c SYS_REFCURSOR;
    OPEN c FOR SELECT 1, 2;
    FETCH c INTO a, b;
    CLOSE c;
  END;
BEGIN
  DECLARE c SYS_REFCURSOR;
  OPEN c FOR SELECT 1, 2;
  FETCH c INTO a, b;
  CLOSE c;
  END;
END;
$$
DELIMITER ;$$
SHOW PROCEDURE CODE pkg.p1;
SHOW PACKAGE BODY CODE pkg;
DROP PACKAGE pkg;
