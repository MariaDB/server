#
# MDEV-20034 Add support for the pre-defined weak SYS_REFCURSOR
#
CREATE PROCEDURE p1()
BEGIN
DECLARE c SYS_REFCURSOR;
DECLARE a, b INT;
OPEN c FOR SELECT 1, 2;
FETCH c INTO a, b;
CLOSE c;
END;
$$
SHOW PROCEDURE CODE p1;
Pos	Instruction
0	set c@0 NULL
1	set a@1 NULL
2	set b@2 NULL
3	copen SESSION.cursor[c@0]
4	cfetch SESSION.cursor[c@0] a@1 b@2
5	cclose SESSION.cursor[c@0]
6	destruct c@0
DROP PROCEDURE p1;
CREATE PACKAGE pkg
PROCEDURE p1();
END;
$$
CREATE PACKAGE BODY pkg
DECLARE a, b INT;
PROCEDURE p1()
BEGIN
DECLARE c SYS_REFCURSOR;
OPEN c FOR SELECT 1, 2;
FETCH c INTO a, b;
CLOSE c;
END;
BEGIN
DECLARE c SYS_REFCURSOR;
OPEN c FOR SELECT 1, 2;
FETCH c INTO a, b;
CLOSE c;
END;
END;
$$
SHOW PROCEDURE CODE pkg.p1;
Pos	Instruction
0	set c@0 NULL
1	copen SESSION.cursor[c@0]
2	cfetch SESSION.cursor[c@0] PACKAGE_BODY.a@0 PACKAGE_BODY.b@1
3	cclose SESSION.cursor[c@0]
4	destruct c@0
SHOW PACKAGE BODY CODE pkg;
Pos	Instruction
0	set a@0 NULL
1	set b@1 NULL
2	set c@2 NULL
3	copen SESSION.cursor[c@2]
4	cfetch SESSION.cursor[c@2] a@0 b@1
5	cclose SESSION.cursor[c@2]
6	destruct c@2
DROP PACKAGE pkg;
