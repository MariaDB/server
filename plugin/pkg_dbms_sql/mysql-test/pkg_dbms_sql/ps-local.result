SET NAMES utf8mb3;
CREATE PROCEDURE p1()
BEGIN
DECLARE spvar VARCHAR(32) DEFAULT 'stmt';
PREPARE LOCAL spvar FROM 'SELECT 1 AS c0';
EXECUTE LOCAL spvar;
DEALLOCATE PREPARE LOCAL spvar;
END;
$$
CALL p1;
c0
1
DROP PROCEDURE p1;
CREATE PROCEDURE p1()
BEGIN
DECLARE spvar VARCHAR(32) DEFAULT 'stmt';
PREPARE stmt FROM 'SELECT 1 AS c0';
EXECUTE LOCAL spvar;
DEALLOCATE PREPARE LOCAL spvar;
END;
$$
CALL p1;
c0
1
DROP PROCEDURE p1;
