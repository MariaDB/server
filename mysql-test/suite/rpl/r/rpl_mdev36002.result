include/master-slave.inc
[connection master]
connection slave;
CHANGE MASTER TO 
MASTER_CONNECT_RETRY = 1;
include/start_slave.inc
SET @saved_dbug = @@GLOBAL.debug_dbug;
SET GLOBAL debug_dbug = "+d,set_slave_err_count_near_overflow,sync_master_retry";
include/rpl_stop_server.inc [server_number=1]
connection slave;
SET DEBUG_SYNC= 'now WAIT_FOR master_retry_sleep';
Slave_IO_Running: Connecting
SET DEBUG_SYNC= 'now SIGNAL master_retry_continue';
SET DEBUG_SYNC= 'now WAIT_FOR master_retry_sleep';
Slave_IO_Running: Connecting
SET DEBUG_SYNC= 'now SIGNAL master_retry_continue';
SET DEBUG_SYNC= 'now WAIT_FOR master_retry_sleep';
Slave_IO_Running: Connecting
SET DEBUG_SYNC= 'now SIGNAL master_retry_continue';
include/rpl_start_server.inc [server_number=1]
SET DEBUG_SYNC= 'RESET';
SET @@GLOBAL.debug_dbug = @saved_dbug;
connection master;
connection slave;
connection slave;
Slave_IO_Running: Yes
include/rpl_end.inc
