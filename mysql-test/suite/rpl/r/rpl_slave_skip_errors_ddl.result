# MDEV-26479 Add support for slave_skip_errors="ddl_exist_errors"
include/master-slave.inc
[connection master]
# we just verfiy that codes is set correctly
connection slave;
SHOW VARIABLES LIKE 'slave_skip_errors';
Variable_name	Value
slave_skip_errors	1007,1008,1050,1051,1054,1060,1061,1068,1091,1146
connection master;
CREATE TABLE t1 (a INT PRIMARY KEY);
