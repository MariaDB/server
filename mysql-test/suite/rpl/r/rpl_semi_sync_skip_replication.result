include/master-slave.inc
[connection master]
connection master;
call mtr.add_suppression("Timeout waiting for reply of binlog");
call mtr.add_suppression("Semi-sync master.*waiting for slave reply");
#
# MDEV-38486: Semi-sync must not await ACK for transactions marked
# with @@skip_replication=1. The replica never receives such events
# so an ACK can never arrive, hanging the primary until timeout.
#
connection master;
SET @old_timeout= @@global.rpl_semi_sync_master_timeout;
SET GLOBAL rpl_semi_sync_master_timeout= 2000;
# Enable FILTER_ON_MASTER on slave so the dump thread stops sending
# skip_replication events to the replica (triggering the hang condition).
connection slave;
include/stop_slave.inc
SET @old_skip= @@global.replicate_events_marked_for_skip;
SET GLOBAL replicate_events_marked_for_skip= FILTER_ON_MASTER;
include/start_slave.inc
connection master;
#
# Step 1: Normal (replicated) transaction — ACKed by replica normally.
#
CREATE TABLE t1 (a INT);
INSERT INTO t1 VALUES (1);
include/save_master_gtid.inc
connection slave;
include/sync_with_master_gtid.inc
#
# Step 2: Transaction with @@skip_replication=1.
# This must NOT hang waiting for an ACK.
#
connection master;
SET @old_skip= @@session.skip_replication;
SET SESSION skip_replication= 1;
CREATE DATABASE db_skip;
SET SESSION skip_replication= @old_skip;
# Semi-sync status must remain ON (no timeout / degradation occurred).
# Rpl_semi_sync_master_status is ON -- PASS
#
# Cleanup
#
connection master;
SET GLOBAL rpl_semi_sync_master_timeout= @old_timeout;
DROP DATABASE IF EXISTS db_skip;
DROP TABLE t1;
include/save_master_gtid.inc
connection slave;
include/stop_slave.inc
SET GLOBAL replicate_events_marked_for_skip= @old_skip;
include/start_slave.inc
include/sync_with_master_gtid.inc
include/rpl_end.inc
