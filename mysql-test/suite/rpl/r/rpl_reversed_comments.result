include/rpl_init.inc [topology=1->2, 2->3]
connection server_1;
CREATE TABLE t1(c1 INT);
include/show_binlog_events.inc
Log_name	Pos	Event_type	Server_id	End_log_pos	Info
master-bin.000001	#	Gtid	#	#	GTID #-#-#
