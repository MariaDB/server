master-bin.000001	#	Query	#	#	COMMIT
master-bin.000001	#	Gtid	#	#	BEGIN GTID #-#-#
master-bin.000001	#	Query	#	#	use `test`; INSERT INTO t1 VALUES(/*M!!       80 + */ 1)
master-bin.000001	#	Query	#	#	COMMIT
