#
# MDEV-36002: --master-retry-count=0 can still stop
#
# Before testing, --master-connect-retry will be set as 1 second and local variable 
# err_count will be set as (ULONG_MAX - 2) to simulate overflow. In the test, 
# during shutdown of the master, the slave will try to reconnect to the master 3 times. 
# After the master restarts up, the slave should reconnect to the master successfully. 
# The simulation will be performed with --master-retry-count values of 0 and 5 respectively.


# stop the slave
--let $rpl_skip_start_slave= 1
--source include/master-slave.inc

--connection slave 
CHANGE MASTER TO 
   MASTER_CONNECT_RETRY = 1;
--source include/start_slave.inc

SET @saved_dbug = @@GLOBAL.debug_dbug;
SET GLOBAL debug_dbug = "+d,set_slave_err_count_near_overflow,sync_master_retry";

# stop the master
--let $rpl_server_number = 1
--source include/rpl_stop_server.inc

--connection slave

--let $retry = 3
while ($retry > 0) {
   SET DEBUG_SYNC= 'now WAIT_FOR master_retry_sleep'; 

   # check slave io thread state which should be Connecting
   --let $slave_io_running = query_get_value("SHOW SLAVE STATUS", Slave_IO_Running, 1)
   --echo Slave_IO_Running: $slave_io_running

   SET DEBUG_SYNC= 'now SIGNAL master_retry_continue'; 
   --dec $retry
}


--let $rpl_server_number= 1
--source include/rpl_start_server.inc

SET DEBUG_SYNC= 'RESET';

SET @@GLOBAL.debug_dbug = @saved_dbug;

# wait until the slave reconnect to the master successfully
--connection master
--sync_slave_with_master

# the slave reconnecting to the master should success
--let $slave_io_running = query_get_value("SHOW SLAVE STATUS", Slave_IO_Running, 1)
--echo Slave_IO_Running: $slave_io_running

--source include/rpl_end.inc
