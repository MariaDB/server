#
# MDEV-36002: --master-retry-count=0 can still stop
#
# master_retry_count is set as 0 or 10 and master_connect_retry as 1 second. The master will be 
# shutdown for 5 seconds, during this time the replica should attempt to reconnect to the 
# master continuously. After 5 seconds, the master will be restarted, and the reconnection 
# from the replica should success, which means it's Slave_IO_Running status should be Yes.
#


--let $rpl_skip_start_slave= 1
--source include/master-slave.inc

--connection slave 

SET @saved_dbug = @@GLOBAL.debug_dbug;

SET GLOBAL debug_dbug = "d,set_slave_err_count_near_overflow";

CHANGE MASTER TO 
   MASTER_CONNECT_RETRY = 1;
--source include/start_slave.inc

# stop the master
--let $rpl_server_number = 1
--source include/rpl_stop_server.inc

# during sleep, the slave should try to reconnect to the master continuously
--sleep 5

--let $rpl_server_number= 1
--source include/rpl_start_server.inc

SET @@GLOBAL.debug_dbug = @saved_dbug;

--connection master
--sync_slave_with_master

# the slave reconnecting to the master should success
--let $slave_io_running = query_get_value("SHOW SLAVE STATUS", Slave_IO_Running, 1)
--echo Slave_IO_Running: $slave_io_running

--source include/rpl_end.inc
