--echo #
--echo # MDEV-38899: Assert !((f->flags & NO_DEFAULT_VALUE_FLAG) && f->vcol_info)
--echo # in prepare_record() with binlog_row_image=NOBLOB and UNIQUE BLOB column
--echo #

--connection server_1
SET GLOBAL binlog_row_image = NOBLOB;

CREATE TABLE t1 (id INT PRIMARY KEY, b BLOB NOT NULL, UNIQUE KEY (b(32))) ENGINE=InnoDB;
INSERT INTO t1 VALUES (1, 'hello');
INSERT INTO t1 VALUES (2, 'world');
--source include/rpl_sync.inc

--connection server_2
SELECT id, CONVERT(b USING utf8) AS b FROM t1 ORDER BY id;

--connection server_1
UPDATE t1 SET id = 10 WHERE id = 1;
--source include/rpl_sync.inc

--connection server_2
SELECT id, CONVERT(b USING utf8) AS b FROM t1 ORDER BY id;

--connection server_1
DELETE FROM t1 WHERE id = 2;
--source include/rpl_sync.inc

--connection server_2
SELECT id, CONVERT(b USING utf8) AS b FROM t1 ORDER BY id;

--connection server_1
SET GLOBAL binlog_row_image = DEFAULT;
DROP TABLE t1;
--source include/rpl_sync.inc
