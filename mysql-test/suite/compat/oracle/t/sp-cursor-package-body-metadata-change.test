-- source include/have_debug.inc

SET sql_mode=ORACLE;

--echo #
--echo # MDEV-36053 CURSOR declarations in PACKAGE BODY
--echo #

SET sql_mode=ORACLE;
DELIMITER /;
CREATE OR REPLACE PACKAGE pkg AS
  FUNCTION f1 RETURN INT;
END;
/
CREATE PACKAGE BODY pkg AS
  CURSOR cur IS SELECT a FROM t1;
  FUNCTION f1 RETURN TEXT AS
    vc TEXT := 0;
  BEGIN
    OPEN cur;
    FETCH cur INTO vc;
    CLOSE cur;
    RETURN vc;
  END;
END;
/
DELIMITER ;/

CREATE TABLE t1 (a INT);
INSERT INTO t1 VALUES (10);
SELECT pkg.f1();
SELECT pkg.f1();
ALTER TABLE t1 MODIFY a TEXT;
UPDATE t1 SET a=CONCAT('a',a);
SELECT pkg.f1();
SELECT pkg.f1();
SELECT pkg.f1();
DROP TABLE t1;
DROP PACKAGE pkg;
