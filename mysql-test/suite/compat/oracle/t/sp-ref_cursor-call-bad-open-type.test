# Error detected during CALL type
# Related to wrong data types in OPEN

SET sql_mode=ORACLE;

--echo #
--echo # MDEV-10152 Add support for TYPE .. IS REF CURSOR
--echo #

CREATE TABLE t1 (a INT, b VARCHAR(10), c VARCHAR(10));
INSERT INTO t1 VALUES (1,'b1','c1');
DELIMITER $$;
CREATE PROCEDURE p1 IS
  TYPE rec_t IS RECORD (a INT, b VARCHAR(10));
  TYPE cur_t IS REF CURSOR RETURN rec_t;
  c0 cur_t;
  v0 rec_t;
BEGIN
  OPEN c0 FOR SELECT * FROM t1;
END;
$$
DELIMITER ;$$
--error ER_ILLEGAL_PARAMETER_DATA_TYPES2_FOR_OPERATION
CALL p1;
DROP PROCEDURE p1;
DROP TABLE t1;


DELIMITER $$;
CREATE PROCEDURE p1 IS
  TYPE rec0_t IS RECORD (a INT, b INET6);
  TYPE cur0_t IS REF CURSOR RETURN rec0_t;
  c0 cur0_t;
BEGIN
  OPEN c0 FOR SELECT 1,TIME'10:20:30' FROM DUAL;
END;
$$
DELIMITER ;$$
--error ER_ILLEGAL_PARAMETER_DATA_TYPES2_FOR_OPERATION
CALL p1;
DROP PROCEDURE p1;


CREATE TABLE t1 (a INT, b INET6);
DELIMITER $$;
CREATE PROCEDURE p1 IS
  TYPE rec0_t IS RECORD (a INT, b TIME);
  TYPE cur0_t IS REF CURSOR RETURN rec0_t;
  c0 cur0_t;
BEGIN
  OPEN c0 FOR SELECT * FROM t1;
END;
$$
DELIMITER ;$$
--error ER_ILLEGAL_PARAMETER_DATA_TYPES2_FOR_OPERATION
CALL p1;
DROP PROCEDURE p1;
DROP TABLE t1;
