--source sp-ref_cursor-fetch-table-rowtype-into-table-rowtype-bad.inc

--echo # Using cursor%ROWTYPE

--source sp-ref_cursor-fetch-cursor-rowtype-into-list-bad.inc
--source sp-ref_cursor-fetch-cursor-rowtype-into-row-bad.inc
--source sp-ref_cursor-fetch-cursor-rowtype-into-cursor-rowtype-bad.inc
