#
# REF CURSOR with RETURN, with FETCH INTO record_variable
# VARCHAR to TIMESTAMP to VARCHAR conversion
#
CREATE TABLE t1 (a INT, b VARCHAR(30));
INSERT INTO t1 VALUES (1,'2001-01-01 ');
INSERT INTO t1 VALUES (1,'2001-01-01 10:20:30.123 ');
INSERT INTO t1 VALUES (1,'2001-01-01 10:20:30.123456 ');
CREATE PROCEDURE p1 IS
TYPE rec0_t IS RECORD (a INT, b TIMESTAMP(6));
TYPE cur0_t IS REF CURSOR RETURN rec0_t;
c0 cur0_t;
v0 t1%ROWTYPE;
BEGIN
OPEN c0 FOR SELECT * FROM t1;
LOOP
FETCH c0 INTO v0;
EXIT WHEN c0%NOTFOUND;
SELECT LENGTH(v0.a) || ' ' || LENGTH(v0.b) || ' <'|| v0.a || '><'|| v0.b || '>' AS line;
END LOOP;
CLOSE c0;
END;
$$
CALL p1;
line
1 26 <1><2001-01-01 00:00:00.000000>
line
1 26 <1><2001-01-01 10:20:30.123000>
line
1 26 <1><2001-01-01 10:20:30.123456>
SHOW PROCEDURE CODE p1;
Pos	Instruction
0	set c0@0 NULL
1	set v0@1 NULL
2	copen STMT.cursor[c0@0]
3	set _cursor_fetch_tmp_var@2 NULL
4	cfetch STMT.cursor[c0@0] _cursor_fetch_tmp_var@2
5	set v0@1 _cursor_fetch_tmp_var@2
6	jump_if_not 8(0) "c0"%NOTFOUND
7	jump 10
8	stmt 0 "SELECT LENGTH(v0.a) || ' ' || LENGTH(..."
9	jump 3
10	cclose STMT.cursor[c0@0]
11	destruct sys_refcursor c0@0
DROP PROCEDURE p1;
