4	cursor_copy_struct cursor_sample _cursor_fetch_tmp_var@2
5	set _cursor_fetch_tmp_var@2 NULL
6	cfetch STMT.cursor[c0@0] _cursor_fetch_tmp_var@2
7	set v0@1 _cursor_fetch_tmp_var@2
8	cclose STMT.cursor[c0@0]
9	stmt 0 "SELECT LENGTH(v0.a) || ' ' || LENGTH(..."
10	cpop 1
11	destruct sys_refcursor c0@0
DROP PROCEDURE p1;
DROP TABLE t1;
