#
# REF CURSOR with RETURN, with FETCH INTO record_variable
# VARCHAR to INT to VARCHAR conversion
# Using cursor ROWTYPE
#
CREATE TABLE t1 (a INT, b VARCHAR(10));
INSERT INTO t1 VALUES (1,'2 ');
CREATE PROCEDURE p1 AS
TYPE rec1_t IS RECORD (a INT, b VARCHAR(10));
CURSOR cursor_sample IS SELECT a, CAST(b AS INT) AS b FROM t1;
TYPE cur0_t IS REF CURSOR RETURN cursor_sample%ROWTYPE;
c0 cur0_t;
v0 rec1_t;
BEGIN
OPEN c0 FOR SELECT a, b FROM t1;
FETCH c0 INTO v0;
CLOSE c0;
SELECT LENGTH(v0.a) || ' ' || LENGTH(v0.b) || ' <'|| v0.a || '><'|| v0.b || '> ' AS line;
END;
$$
CALL p1;
line
1 1 <1><2> 
