SET sql_mode=ORACLE;
#
# MDEV-10152 Add support for TYPE .. IS REF CURSOR
#
SET @debug_ref_cursor=TRUE;
#
# REF CURSOR with RETURN, with FETCH INTO record_variable
# VARCHAR to INT to VARCHAR conversion
#
CREATE PROCEDURE p1 AS
TYPE rec0_t IS RECORD (a INT, b INT);
TYPE rec1_t IS RECORD (a INT, b VARCHAR(10));
TYPE cur0_t IS REF CURSOR RETURN rec0_t;
c0 cur0_t;
v0 rec1_t;
BEGIN
OPEN c0 FOR SELECT '1', '2 ' FROM DUAL;
FETCH c0 INTO v0;
SELECT LENGTH(v0.a) || ' ' || LENGTH(v0.b) || ' <'|| v0.a || '><'|| v0.b || '> ' AS line;
CLOSE c0;
END;
$$
CALL p1;
line
1 1 <1><2> 
Warnings:
Note	1265	Data truncated for column 'b' at row 1
SHOW PROCEDURE CODE p1;
Pos	Instruction
0	set c0@0 NULL
1	set v0@1 NULL
2	copen STMT.cursor[c0@0]
3	set _cursor_fetch_tmp_var@2 NULL
4	cfetch STMT.cursor[c0@0] _cursor_fetch_tmp_var@2
5	set v0@1 _cursor_fetch_tmp_var@2
6	stmt 0 "SELECT LENGTH(v0.a) || ' ' || LENGTH(..."
7	cclose STMT.cursor[c0@0]
8	destruct sys_refcursor c0@0
DROP PROCEDURE p1;
