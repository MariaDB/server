SET sql_mode=ORACLE;
#
# MDEV-10152 Add support for TYPE .. IS REF CURSOR
#
CREATE TABLE t1 (a INT);
INSERT INTO t1 VALUES (1);
CREATE PROCEDURE p1 IS
CURSOR cursor_sample IS SELECT * FROM t1;
/*empty*/
TYPE cur_t IS REF CURSOR RETURN cursor_sample%ROWTYPE;
c0 cur_t;
v0a INT;
BEGIN
OPEN c0 FOR SELECT * FROM t1;
FETCH c0 INTO v0a;
CLOSE c0;
SELECT v0a;
END;
$$
CALL p1;
v0a
1
DROP PROCEDURE p1;
DROP TABLE t1;
CREATE TABLE t1 (a INT, b VARCHAR(10));
INSERT INTO t1 VALUES (1, 'b1');
CREATE PROCEDURE p1 IS
CURSOR cursor_sample IS SELECT * FROM t1;
/*empty*/
TYPE cur_t IS REF CURSOR RETURN cursor_sample%ROWTYPE;
c0 cur_t;
v0a INT;
v0b VARCHAR(10);
BEGIN
OPEN c0 FOR SELECT * FROM t1;
FETCH c0 INTO v0a, v0b;
CLOSE c0;
SELECT v0a, v0b;
END;
$$
CALL p1;
v0a	v0b
1	b1
DROP PROCEDURE p1;
DROP TABLE t1;
