SET sql_mode=ORACLE;
#
# MDEV-10152 Add support for TYPE .. IS REF CURSOR
#
CREATE TABLE t1 (a INT, b VARCHAR(10), c VARCHAR(10));
INSERT INTO t1 VALUES (1,'b1','c1');
CREATE PROCEDURE p1 IS
TYPE rec_t IS RECORD (a INT, b VARCHAR(10));
TYPE cur_t IS REF CURSOR RETURN rec_t;
c0 cur_t;
v0 rec_t;
BEGIN
OPEN c0 FOR SELECT * FROM t1;
END;
$$
CALL p1;
ERROR HY000: Illegal parameter data types row<2> and row<3> for operation 'OPEN .. FOR'
DROP PROCEDURE p1;
DROP TABLE t1;
CREATE PROCEDURE p1 IS
TYPE rec0_t IS RECORD (a INT, b INET6);
TYPE cur0_t IS REF CURSOR RETURN rec0_t;
c0 cur0_t;
BEGIN
OPEN c0 FOR SELECT 1,TIME'10:20:30' FROM DUAL;
END;
$$
CALL p1;
ERROR HY000: Illegal parameter data types time and inet6 for operation 'OPEN'
DROP PROCEDURE p1;
CREATE TABLE t1 (a INT, b INET6);
CREATE PROCEDURE p1 IS
TYPE rec0_t IS RECORD (a INT, b TIME);
TYPE cur0_t IS REF CURSOR RETURN rec0_t;
c0 cur0_t;
BEGIN
OPEN c0 FOR SELECT * FROM t1;
END;
$$
CALL p1;
ERROR HY000: Illegal parameter data types inet6 and time for operation 'OPEN'
DROP PROCEDURE p1;
DROP TABLE t1;
