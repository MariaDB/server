CREATE PACKAGE BODY pkg AS
CURSOR cur IS SELECT 1 AS c FROM DUAL;
vc0 INT;
vc1 INT;
FUNCTION f1 RETURN INT AS
BEGIN
OPEN cur;
FETCH cur INTO vc1;
