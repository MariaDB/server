#
# RECORD with field manipulations
#
DECLARE
TYPE DeptRecTyp IS RECORD (
dept_id    NUMBER(4)
);
dept_rec DeptRecTyp;
test INT:=4;
BEGIN
dept_rec.dept_id:= 2;
test:= test + dept_rec.dept_id;
dept_rec.dept_id:= 5;
SELECT dept_rec.dept_id, test;
END;
$$
dept_rec.dept_id	test
5	6
