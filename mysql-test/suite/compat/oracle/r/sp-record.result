#
# Nested RECORDs
# This is not supported yet
#
DECLARE
TYPE name_rec IS RECORD (
first  VARCHAR(64),
last   VARCHAR(64)
);
TYPE contact IS RECORD (
name  name_rec,     -- a nested record
phone VARCHAR(32)
);
person contact;
str VARCHAR(1024);
BEGIN
person.name.first := 'John';
person.name.last := 'Brown';
person.phone := '1-654-222-1234';
str:= 
person.name.first  || ' ' ||
person.name.last   || ', ' ||
person.phone;
SELECT str;
END;
$$
