SET sql_mode=ORACLE;
#
# MDEV-10152 Add support for TYPE .. IS REF CURSOR
#
#
# REF CURSOR with RETURN, with FETCH INTO record_variable
# VARCHAR to INT to VARCHAR conversion
#
CREATE PROCEDURE p1 AS
TYPE rec0_t IS RECORD (a INT, b INT);
TYPE rec1_t IS RECORD (a INT, b VARCHAR(10));
TYPE cur0_t IS REF CURSOR RETURN rec0_t;
c0 cur0_t;
v0 rec1_t;
BEGIN
OPEN c0 FOR SELECT '1', '2 ' FROM DUAL;
FETCH c0 INTO v0;
SELECT LENGTH(v0.a) || ' ' || LENGTH(v0.b) || ' <'|| v0.a || '><'|| v0.b || '> ' AS line;
CLOSE c0;
END;
$$
CALL p1;
line
1 1 <1><2> 
Warnings:
Note	1265	Data truncated for column 'b' at row 1
DROP PROCEDURE p1;
#
# REF CURSOR with RETURN, with FETCH INTO record_variable
# VARCHAR to INT to VARCHAR conversion
# Using table ROWTYPE
#
CREATE TABLE table_sample (a INT, b INT);
CREATE PROCEDURE p1 AS
TYPE rec1_t IS RECORD (a INT, b VARCHAR(10));
TYPE cur0_t IS REF CURSOR RETURN table_sample%ROWTYPE;
c0 cur0_t;
v0 rec1_t;
BEGIN
OPEN c0 FOR SELECT 1,'2 ' FROM DUAL;
FETCH c0 INTO v0;
SELECT LENGTH(v0.a) || ' ' || LENGTH(v0.b) || ' <'|| v0.a || '><'|| v0.b || '> ' AS line;
CLOSE c0;
END;
$$
CALL p1;
line
1 1 <1><2> 
Warnings:
Note	1265	Data truncated for column 'b' at row 1
DROP PROCEDURE p1;
DROP TABLE table_sample;
#
# REF CURSOR with RETURN, with FETCH INTO record_variable
# VARCHAR to INT to VARCHAR conversion
# Using cursor ROWTYPE
#
CREATE TABLE t1 (a INT, b VARCHAR(10));
INSERT INTO t1 VALUES (1,'2 ');
CREATE PROCEDURE p1 AS
TYPE rec1_t IS RECORD (a INT, b VARCHAR(10));
CURSOR cursor_sample IS SELECT a, CAST(b AS INT) AS b FROM t1;
TYPE cur0_t IS REF CURSOR RETURN cursor_sample%ROWTYPE;
c0 cur0_t;
v0 rec1_t;
BEGIN
OPEN c0 FOR SELECT a, b FROM t1;
FETCH c0 INTO v0;
CLOSE c0;
SELECT LENGTH(v0.a) || ' ' || LENGTH(v0.b) || ' <'|| v0.a || '><'|| v0.b || '> ' AS line;
END;
$$
CALL p1;
line
1 1 <1><2> 
Warnings:
Note	1265	Data truncated for column 'b' at row 1
DROP PROCEDURE p1;
DROP TABLE t1;
#
# REF CURSOR with RETURN, with FETCH INTO record_variable
# VARCHAR to INT to VARCHAR conversion
#
# Using explicit ROW type
CREATE PROCEDURE p1 AS
TYPE rec0_t IS RECORD (a INT, b INT);
TYPE cur0_t IS REF CURSOR RETURN rec0_t;
c0 cur0_t;
v0a INT;
v0b VARCHAR(10);
BEGIN
OPEN c0 FOR SELECT '1', '2 ' FROM DUAL;
FETCH c0 INTO v0a, v0b;
SELECT LENGTH(v0a) || ' ' || LENGTH(v0b) || ' <'|| v0a || '><'|| v0b || '> ' AS line;
CLOSE c0;
END;
$$
CALL p1;
line
1 1 <1><2> 
Warnings:
Note	1265	Data truncated for column 'b' at row 1
DROP PROCEDURE p1;
