#
# REF CURSOR with RETURN, with FETCH INTO record_variable
# VARCHAR to TIMESTAMP to VARCHAR conversion
#
CREATE TABLE t1 (a INT, b VARCHAR(30));
INSERT INTO t1 VALUES (1,'2001-01-01 ');
INSERT INTO t1 VALUES (1,'2001-01-01 10:20:30.123 ');
INSERT INTO t1 VALUES (1,'2001-01-01 10:20:30.123456 ');
CREATE PROCEDURE p1 IS
TYPE rec0_t IS RECORD (a INT, b TIMESTAMP(6));
TYPE cur0_t IS REF CURSOR RETURN rec0_t;
c0 cur0_t;
v0 t1%ROWTYPE;
BEGIN
OPEN c0 FOR SELECT * FROM t1;
LOOP
FETCH c0 INTO v0;
EXIT WHEN c0%NOTFOUND;
SELECT LENGTH(v0.a) || ' ' || LENGTH(v0.b) || ' <'|| v0.a || '><'|| v0.b || '>' AS line;
END LOOP;
CLOSE c0;
END;
$$
CALL p1;
line
1 26 <1><2001-01-01 00:00:00.000000>
line
1 26 <1><2001-01-01 10:20:30.123000>
line
1 26 <1><2001-01-01 10:20:30.123456>
DROP PROCEDURE p1;
#
# REF CURSOR with RETURN, with FETCH INTO record_variable
# VARCHAR to TIMESTAMP to VARCHAR conversion
# Using table%ROWTYPE
#
CREATE TABLE table_sample (a INT, b TIMESTAMP(6));
CREATE PROCEDURE p1 IS
TYPE cur0_t IS REF CURSOR RETURN table_sample%ROWTYPE;
c0 cur0_t;
v0 t1%ROWTYPE;
BEGIN
OPEN c0 FOR SELECT * FROM t1;
LOOP
FETCH c0 INTO v0;
EXIT WHEN c0%NOTFOUND;
SELECT LENGTH(v0.a) || ' ' || LENGTH(v0.b) || ' <'|| v0.a || '><'|| v0.b || '>' AS line;
END LOOP;
CLOSE c0;
END;
$$
CALL p1;
line
1 26 <1><2001-01-01 00:00:00.000000>
line
1 26 <1><2001-01-01 10:20:30.123000>
line
1 26 <1><2001-01-01 10:20:30.123456>
DROP TABLE table_sample;
DROP PROCEDURE p1;
#
# REF CURSOR with RETURN, with FETCH INTO record_variable
# VARCHAR to TIMESTAMP to VARCHAR conversion
# Using cursor%ROWTYPE
#
CREATE PROCEDURE p1 IS
CURSOR cursor_sample IS SELECT a, CAST(b AS DATETIME(6)) AS b FROM t1;
TYPE cur0_t IS REF CURSOR RETURN cursor_sample%ROWTYPE;
c0 cur0_t;
v0 t1%ROWTYPE;
BEGIN
OPEN c0 FOR SELECT * FROM t1;
LOOP
FETCH c0 INTO v0;
EXIT WHEN c0%NOTFOUND;
SELECT LENGTH(v0.a) || ' ' || LENGTH(v0.b) || ' <'|| v0.a || '><'|| v0.b || '>' AS line;
END LOOP;
CLOSE c0;
END;
$$
CALL p1;
line
1 26 <1><2001-01-01 00:00:00.000000>
line
1 26 <1><2001-01-01 10:20:30.123000>
line
1 26 <1><2001-01-01 10:20:30.123456>
DROP PROCEDURE p1;
DROP TABLE t1;
#
# REF CURSOR with RETURN, with FETCH INTO record_variable
# VARCHAR to TIMESTAMP to VARCHAR conversion
#
CREATE TABLE t1 (a INT, b VARCHAR(30));
INSERT INTO t1 VALUES (1,'2001-01-01 ');
INSERT INTO t1 VALUES (1,'2001-01-01 10:20:30.123 ');
INSERT INTO t1 VALUES (1,'2001-01-01 10:20:30.123456 ');
# Using explicit cursor
CREATE PROCEDURE p1 IS
TYPE rec0_t IS RECORD (a INT, b TIMESTAMP(6));
TYPE cur0_t IS REF CURSOR RETURN rec0_t;
c0 cur0_t;
v0a t1.a%TYPE;
v0b t1.b%TYPE;
BEGIN
OPEN c0 FOR SELECT * FROM t1;
LOOP
FETCH c0 INTO v0a, v0b;
EXIT WHEN c0%NOTFOUND;
SELECT LENGTH(v0a) || ' ' || LENGTH(v0b) || ' <'|| v0a || '><'|| v0b || '>' AS line;
END LOOP;
CLOSE c0;
END;
$$
CALL p1;
line
1 26 <1><2001-01-01 00:00:00.000000>
line
1 26 <1><2001-01-01 10:20:30.123000>
line
1 26 <1><2001-01-01 10:20:30.123456>
DROP PROCEDURE p1;
# Using table%ROWTYPE
CREATE TABLE table_sample (a INT, b TIMESTAMP(6));
CREATE PROCEDURE p1 IS
TYPE cur0_t IS REF CURSOR RETURN table_sample%ROWTYPE;
c0 cur0_t;
v0a t1.a%TYPE;
v0b t1.b%TYPE;
BEGIN
OPEN c0 FOR SELECT * FROM t1;
LOOP
FETCH c0 INTO v0a, v0b;
EXIT WHEN c0%NOTFOUND;
SELECT LENGTH(v0a) || ' ' || LENGTH(v0b) || ' <'|| v0a || '><'|| v0b || '>' AS line;
END LOOP;
CLOSE c0;
END;
$$
CALL p1;
line
1 26 <1><2001-01-01 00:00:00.000000>
line
1 26 <1><2001-01-01 10:20:30.123000>
line
1 26 <1><2001-01-01 10:20:30.123456>
DROP TABLE table_sample;
DROP PROCEDURE p1;
# Using cursor%ROWTYPE
CREATE TABLE table_sample (a INT, b TIMESTAMP(6));
CREATE PROCEDURE p1 IS
CURSOR cursor_sample IS SELECT a, b FROM table_sample;
TYPE cur0_t IS REF CURSOR RETURN cursor_sample%ROWTYPE;
c0 cur0_t;
v0a t1.a%TYPE;
v0b t1.b%TYPE;
BEGIN
OPEN c0 FOR SELECT * FROM t1;
LOOP
FETCH c0 INTO v0a, v0b;
EXIT WHEN c0%NOTFOUND;
SELECT LENGTH(v0a) || ' ' || LENGTH(v0b) || ' <'|| v0a || '><'|| v0b || '>' AS line;
END LOOP;
CLOSE c0;
END;
$$
