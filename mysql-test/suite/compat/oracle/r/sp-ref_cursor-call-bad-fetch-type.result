SET sql_mode=ORACLE;
#
# MDEV-10152 Add support for TYPE .. IS REF CURSOR
#
# Using table%ROWTYPE
CREATE TABLE t1 (a INT, b VARCHAR(10));
INSERT INTO t1 VALUES (1,'b1');
CREATE PROCEDURE p1 IS
/*empty*/
/*empty*/
TYPE cur_t IS REF CURSOR RETURN t1%ROWTYPE;
c0 cur_t;
v0a INT;
v0b VARCHAR(10);
v0c VARCHAR(10);
BEGIN
OPEN c0 FOR SELECT * FROM t1;
FETCH c0 INTO v0a, v0b, v0c;
END;
$$
CALL p1;
ERROR HY000: Illegal parameter data types ROW<2> and ROW<3> for operation 'FETCH..INTO'
