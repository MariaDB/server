# MDEV-35369: Add is_deprecated column to system_variables table
#
# All deprecated variables and accompanying replacement (will be NULL if none exist)
#
SELECT VARIABLE_NAME, DEPRECATED_REPLACEMENT
FROM INFORMATION_SCHEMA.SYSTEM_VARIABLES
WHERE IS_DEPRECATED = "YES"
ORDER BY VARIABLE_NAME;
VARIABLE_NAME	DEPRECATED_REPLACEMENT
ALTER_ALGORITHM	NULL
BINLOG_OPTIMIZE_THREAD_SCHEDULING	NULL
LOG_SLOW_ADMIN_STATEMENTS	log_slow_filter
METADATA_LOCKS_CACHE_SIZE	NULL
METADATA_LOCKS_HASH_INSTANCES	NULL
OLD_PASSWORDS	NULL
OPTIMIZER_ADJUST_SECONDARY_KEY_COSTS	NULL
SQL_NOTES	note_verbosity
TX_ISOLATION	transaction_isolation
TX_READ_ONLY	transaction_read_only
#
include/assert.inc [Non-deprecated variables (IS_DEPRECATED="NO") must have NULL DEPRECATED_REPLACEMENT]
# end of 13.0 tests
