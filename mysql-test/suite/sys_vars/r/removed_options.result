#
# MDEV-39252 At runtime list removed variables that have been set
#
#
# List INFORMATION_SCHEMA.REMOVED_STARTUP_OPTIONS
# Use --nowarnings
#
SELECT OPTION_NAME, OPTION_VALUE, SOURCE, HANDLING FROM INFORMATION_SCHEMA.REMOVED_STARTUP_OPTIONS;
OPTION_NAME	OPTION_VALUE	SOURCE	HANDLING
innodb-log-files-in-group	2	CONFIG	IGNORED
innodb-thread-concurrency	8	COMMAND_LINE	IGNORED
