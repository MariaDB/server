# Verify the system variable exists and has a valid value
SELECT @@global.parsec_pbkdf2_iterations BETWEEN 0 AND 15 AS valid_default;
valid_default
1
# Verify that different iteration counts produce different PBKDF2 output
SELECT
KDF('password', 'salt', 1024, 'pbkdf2_hmac', 256) !=
KDF('password', 'salt', 2048, 'pbkdf2_hmac', 256) AS different_iters_differ,
KDF('password', 'salt', 1024, 'pbkdf2_hmac', 256) =
KDF('password', 'salt', 1024, 'pbkdf2_hmac', 256) AS same_iters_match;
different_iters_differ	same_iters_match
1	1
# Create user with default iterations
create user iter_default@'%' identified via parsec using PASSWORD('test_pwd');
show grants for iter_default@'%';
Grants for iter_default@%
GRANT USAGE ON *.* TO `iter_default`@`%` IDENTIFIED VIA parsec USING ':iter:salt:password'
# Login should work with default iterations
connect con_default, localhost, iter_default, test_pwd;
select 'default_iterations_login_ok' as result;
result
default_iterations_login_ok
disconnect con_default;
connection default;
# Set iterations to 0 (1024 iterations, legacy)
SET GLOBAL parsec_pbkdf2_iterations = 0;
SELECT @@global.parsec_pbkdf2_iterations;
@@global.parsec_pbkdf2_iterations
0
create user iter_zero@'%' identified via parsec using PASSWORD('test_pwd');
show grants for iter_zero@'%';
Grants for iter_zero@%
GRANT USAGE ON *.* TO `iter_zero`@`%` IDENTIFIED VIA parsec USING 'P0:salt:password'
# Login should work with iterations=0
connect con_zero, localhost, iter_zero, test_pwd;
select 'zero_iterations_login_ok' as result;
result
zero_iterations_login_ok
disconnect con_zero;
connection default;
# Set iterations to 3 (1024 << 3 = 8192 iterations)
SET GLOBAL parsec_pbkdf2_iterations = 3;
SELECT @@global.parsec_pbkdf2_iterations;
@@global.parsec_pbkdf2_iterations
3
create user iter_three@'%' identified via parsec using PASSWORD('test_pwd');
show grants for iter_three@'%';
Grants for iter_three@%
GRANT USAGE ON *.* TO `iter_three`@`%` IDENTIFIED VIA parsec USING 'P3:salt:password'
# Login should work with iterations=3
connect con_three, localhost, iter_three, test_pwd;
select 'three_iterations_login_ok' as result;
result
three_iterations_login_ok
disconnect con_three;
connection default;
# Wrong password should still fail
connect(localhost,iter_three,wrong_pwd,test,MASTER_MYPORT,MASTER_MYSOCK);
connect con_fail, localhost, iter_three, wrong_pwd;
ERROR 28000: Access denied for user 'iter_three'@'localhost' (using password: NO)
# Test hex encoding: set to 10 (1024 << 10 = 1048576 iterations)
SET GLOBAL parsec_pbkdf2_iterations = 10;
SELECT @@global.parsec_pbkdf2_iterations;
@@global.parsec_pbkdf2_iterations
10
create user iter_ten@'%' identified via parsec using PASSWORD('test_pwd');
show grants for iter_ten@'%';
Grants for iter_ten@%
GRANT USAGE ON *.* TO `iter_ten`@`%` IDENTIFIED VIA parsec USING 'Pa:salt:password'
# Login should work with iterations=10
connect con_ten, localhost, iter_ten, test_pwd;
select 'ten_iterations_login_ok' as result;
result
ten_iterations_login_ok
disconnect con_ten;
connection default;
# Test boundary: set to max value 15 (1024 << 15 = 33554432 iterations)
SET GLOBAL parsec_pbkdf2_iterations = 15;
SELECT @@global.parsec_pbkdf2_iterations;
@@global.parsec_pbkdf2_iterations
15
# Test boundary: setting above max should be clamped
SET GLOBAL parsec_pbkdf2_iterations = 16;
Warnings:
Warning	1292	Truncated incorrect parsec_pbkdf2_iterations value: '16'
SELECT @@global.parsec_pbkdf2_iterations;
@@global.parsec_pbkdf2_iterations
15
# Test that users created with different iterations can all still 
# authenticate after changing the global setting
SET GLOBAL parsec_pbkdf2_iterations = 5;
connect con_zero2, localhost, iter_zero, test_pwd;
select 'cross_iter_zero_ok' as result;
result
cross_iter_zero_ok
disconnect con_zero2;
connect con_three2, localhost, iter_three, test_pwd;
select 'cross_iter_three_ok' as result;
result
cross_iter_three_ok
disconnect con_three2;
connect con_default2, localhost, iter_default, test_pwd;
select 'cross_iter_default_ok' as result;
result
cross_iter_default_ok
disconnect con_default2;
connect con_ten2, localhost, iter_ten, test_pwd;
select 'cross_iter_ten_ok' as result;
result
cross_iter_ten_ok
disconnect con_ten2;
connection default;
# ALTER USER should re-hash with current iterations setting
SET GLOBAL parsec_pbkdf2_iterations = 2;
ALTER USER iter_zero@'%' IDENTIFIED via parsec using PASSWORD('new_pwd');
show grants for iter_zero@'%';
Grants for iter_zero@%
GRANT USAGE ON *.* TO `iter_zero`@`%` IDENTIFIED VIA parsec USING 'P2:salt:password'
# Login with new password should work
connect con_altered, localhost, iter_zero, new_pwd;
select 'altered_user_login_ok' as result;
result
altered_user_login_ok
disconnect con_altered;
# Login with old password should fail
connection default;
connect(localhost,iter_zero,test_pwd,test,MASTER_MYPORT,MASTER_MYSOCK);
connect con_old_pwd, localhost, iter_zero, test_pwd;
ERROR 28000: Access denied for user 'iter_zero'@'localhost' (using password: NO)
connection default;
# Cleanup
SET GLOBAL parsec_pbkdf2_iterations = DEFAULT;
drop user iter_default@'%';
drop user iter_zero@'%';
drop user iter_three@'%';
drop user iter_ten@'%';
