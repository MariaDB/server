#
# SR transactions are not binlogged before commit #136
#
--source include/galera_cluster.inc
--source include/force_restart.inc

--connection node_1
SET SESSION wsrep_trx_fragment_size = 1;
SET AUTOCOMMIT=OFF;
START TRANSACTION;
CREATE TABLE t1 (f1 INTEGER) ENGINE=InnoDB;
INSERT INTO t1 VALUES (1),(2);

--connection node_1
#
# At this point above SR transaction should not be in binlog
#
--replace_regex /xid=[0-9]+/xid=###/ /table_id: [0-9]+/table_id: ###/
--replace_column 2 <Pos> 5 <End_log_pos>
SHOW BINLOG EVENTS IN 'mysqld-bin.000002' FROM 374;

COMMIT;

#
# Now SR is in binlog
#
--replace_regex /xid=[0-9]+/xid=###/ /table_id: [0-9]+/table_id: ###/
--replace_column 2 <Pos> 5 <End_log_pos>
SHOW BINLOG EVENTS IN 'mysqld-bin.000002' FROM 374;

SET SESSION wsrep_trx_fragment_size = 0;
INSERT INTO t1 VALUES (3),(4);
COMMIT;

--connection node_2
# Wait for all updates to arrive before dumping binlog
SELECT COUNT(*) = 4 FROM t1;

--connection node_1
DROP TABLE t1;
