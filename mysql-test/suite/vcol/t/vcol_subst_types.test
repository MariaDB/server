explain
SELECT a, COUNT(*) FROM t GROUP BY a;
SELECT a, COUNT(*) FROM t GROUP BY a;
SELECT * FROM t;
DROP TABLE t;

--echo ## enum, enum
CREATE TABLE t (a set('e1', 'e2', 'e3'), b set('e1', 'e2', 'e3') as (a), key(b));
INSERT IGNORE INTO t (a) VALUES ('e1,e2'),('e3'),('e1,e2');
explain
SELECT a, COUNT(*) FROM t GROUP BY a;
SELECT a, COUNT(*) FROM t GROUP BY a;
SELECT * FROM t;
DROP TABLE t;

--echo # Type_handler_geometry

--echo ## varchar, point
CREATE TABLE t (a varchar(20), b point as (a), key(b));
--error ER_CANT_CREATE_GEOMETRY_OBJECT
INSERT IGNORE INTO t (a) VALUES ('point(0,0)'),('point(1,0)'),('point(0,0)');
DROP TABLE t;

--echo ## point, polygon
CREATE TABLE t (a point, b polygon as (a), key(b));
--error ER_TRUNCATED_WRONG_VALUE_FOR_FIELD
INSERT IGNORE INTO t (a) VALUES (point(0,0)),(point(1,0)),(point(0,0));
DROP TABLE t;

--echo ## boundary(linestring), multipoint
--echo ## the type of boundary(linestring) is geometry
CREATE TABLE t (a linestring, b multipoint as (boundary(a)), key(b));
INSERT IGNORE INTO t (a) VALUES
(LineStringFromText('LINESTRING(10 10,20 10,10 10)')),
(LineStringFromText('LINESTRING(10 10,5 10,10 10)')),
(LineStringFromText('LINESTRING(10 10,20 10,5 10)'));
explain
SELECT ST_AsWKT(a), COUNT(*) FROM t GROUP BY boundary(a);
SELECT ST_AsWKT(a), COUNT(*) FROM t GROUP BY boundary(a);
SELECT ST_AsWKT(a), ST_AsWKT(boundary(a)), ST_AsWKT(b) FROM t;
DROP TABLE t;

--echo ## point < point
CREATE TABLE t (a point, b point as (a), key(b));
INSERT IGNORE INTO t (a) VALUES (point(0,0)),(point(1,0)),(point(0,0));
explain
SELECT ST_AsWKT(a), COUNT(*) FROM t GROUP BY a;
SELECT ST_AsWKT(a), COUNT(*) FROM t GROUP BY a;
SELECT ST_AsWKT(a), ST_AsWKT(b) FROM t;
DROP TABLE t;

--echo ## boundary(linestring), geometry
CREATE TABLE t (a linestring, b geometry as (boundary(a)), key(b));
INSERT IGNORE INTO t (a) VALUES
(LineStringFromText('LINESTRING(10 10,20 10,10 10)')),
(LineStringFromText('LINESTRING(10 10,5 10,10 10)')),
(LineStringFromText('LINESTRING(10 10,20 10,5 10)'));
explain
SELECT ST_AsWKT(a), COUNT(*) FROM t GROUP BY boundary(a);
SELECT ST_AsWKT(a), COUNT(*) FROM t GROUP BY boundary(a);
SELECT ST_AsWKT(a), ST_AsWKT(boundary(a)), ST_AsWKT(b) FROM t;
DROP TABLE t;

--echo # Type_handler_fbt

--echo ## varchar, uuid
CREATE TABLE t (a varchar(36), b uuid as (a), key(b));
INSERT IGNORE INTO t (a) VALUES
('ffffffff-ffff-ffff-ffff-fffffffffffe'),
('ffffffff-ffff-ffff-ffff-ffffffffffff'),
('ffffffff-ffff-ffff-ffff-fffffffffffe');
explain
SELECT a, COUNT(*) FROM t GROUP BY a;
SELECT a, COUNT(*) FROM t GROUP BY a;
SELECT * FROM t;
DROP TABLE t;

--echo ## uuid < uuid
CREATE TABLE t (a uuid, b uuid as (a), key(b));
INSERT IGNORE INTO t (a) VALUES
(x'fffffffffffffffffffffffffffffffe'),
(x'ffffffffffffffffffffffffffffffff'),
(x'fffffffffffffffffffffffffffffffe');
explain
SELECT a, COUNT(*) FROM t GROUP BY a LIMIT 2;
SELECT a, COUNT(*) FROM t GROUP BY a LIMIT 2;
SELECT * FROM t;
DROP TABLE t;

--echo ## inet4, inet6
CREATE TABLE t (a inet4, b inet6 as (a), key(b));
INSERT IGNORE INTO t (a) VALUES ('0.0.0.0'), ('255.10.0.0'), ('0.0.0.0');
explain
SELECT a, COUNT(*) FROM t GROUP BY a;
SELECT a, COUNT(*) FROM t GROUP BY a;
SELECT * FROM t;
DROP TABLE t;

--echo ## inet4 < inet4
CREATE TABLE t (a inet4, b inet4 as (a), key(b));
INSERT IGNORE INTO t (a) VALUES ('0.0.0.0'), ('255.10.0.0'), ('0.0.0.0');
explain
SELECT a, COUNT(*) FROM t GROUP BY a LIMIT 2;
SELECT a, COUNT(*) FROM t GROUP BY a LIMIT 2;
SELECT * FROM t;
DROP TABLE t;

--echo # Misc. tests

--echo ## insert then add index
CREATE TABLE t (a INT, va TINYINT AS (a));
SET sql_mode=STRICT_ALL_TABLES;
INSERT INTO t (a) VALUES (100),(150),(200);
SET sql_mode=DEFAULT;
--error ER_WARN_DATA_OUT_OF_RANGE
ALTER TABLE t add index i(a);
drop table t;

--echo ## insert ignore overrides STRICT_ALL_TABLES
CREATE TABLE t (a INT, b TINYINT AS (a), key (b));
SET sql_mode=STRICT_ALL_TABLES;
--error ER_WARN_DATA_OUT_OF_RANGE
INSERT INTO t (a) VALUES (100),(150),(200);
INSERT IGNORE INTO t (a) VALUES (100),(150),(200);
SET sql_mode=DEFAULT;
drop table t;

--echo ## order by also affected
CREATE TABLE t (a INT, va TINYINT AS (a), key (va));
INSERT IGNORE INTO t (a) VALUES (100),(150),(200),(180);
explain
select * from t order by a;
select * from t order by a;
drop table t;

--echo ## where also affected
CREATE TABLE t (a INT, va TINYINT AS (a), key (va));
INSERT IGNORE INTO t (a) VALUES (100),(150),(200),(180);
explain
select * from t where a = 127;
select * from t where a = 127;
drop table t;

--echo ## vcol on vcol
create table t (c tinyint, key (c));
alter table t
  add column vc1 tinyint as (c + 10),
  add index(vc1);
alter table t
  add column vc2 int as (vc1 * 2),
  add index(vc2);
insert ignore into t (c) values (121), (122), (120);
explain
select * from t;
select * from t;
explain
select c from t group by vc2;
select c from t group by vc2;
explain
select vc2 from t group by vc1 * 2;
select vc2 from t group by vc1 * 2;
explain
select * from t group by (c + 10) * 2;
select * from t group by (c + 10) * 2;
explain
select * from t group by c + 10;
select * from t group by c + 10;
drop table t;
