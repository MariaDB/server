--echo ## tinyint + 2, tinyint
CREATE TABLE t (a TINYINT, va TINYINT AS (a + 2), KEY(va));
INSERT IGNORE INTO t (a) VALUES (126),(127);
explain
SELECT a + 2, COUNT(*) FROM t GROUP BY a + 2;
SELECT a + 2, COUNT(*) FROM t GROUP BY a + 2;
SELECT a, a + 2, va FROM t;

DROP TABLE t;

--echo ## tinyint * tinyint, mediumint
CREATE TABLE t (a TINYINT, va MEDIUMINT AS (a * a), KEY(va));
INSERT IGNORE INTO t (a) VALUES (-20),(19);
explain
SELECT a * a, COUNT(*) FROM t GROUP BY a * a;
SELECT a * a, COUNT(*) FROM t GROUP BY a * a;
SELECT a, a * a, va FROM t;

DROP TABLE t;

--echo ## tinyint ** 4, mediumint
CREATE TABLE t (a TINYINT, va MEDIUMINT AS (a * a * a * a), KEY(va));
INSERT IGNORE INTO t (a) VALUES (-101),(100);
explain
SELECT a * a * a * a, COUNT(*) FROM t GROUP BY a * a * a * a;
SELECT a * a * a * a, COUNT(*) FROM t GROUP BY a * a * a * a;
SELECT a, a * a * a * a, va FROM t;

DROP TABLE t;

