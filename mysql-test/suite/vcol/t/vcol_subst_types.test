--echo # Type_handler_time_common

--echo ## datetime, time
CREATE TABLE t (a datetime, b time as (a), key(b));
INSERT IGNORE INTO t (a) VALUES ('2026-01-01 12:00'),('2026-03-01 12:00');
explain
SELECT a, COUNT(*) FROM t GROUP BY a;
SELECT a, COUNT(*) FROM t GROUP BY a;
SELECT * FROM t;

DROP TABLE t;

--echo ## time(3), time(2)
--echo ## table creation with index not allowed
CREATE TABLE t (a time(3), b time(2) as (a));
drop table t;
--error ER_GENERATED_COLUMN_FUNCTION_IS_NOT_ALLOWED
CREATE TABLE t (a time(3), b time(2) as (a), key (b));

--echo ## time(2) < time(3)
CREATE TABLE t (a time(2), b time(3) as (a), key(b));
INSERT IGNORE INTO t (a) VALUES ('12:00.00'),('16:00.00'),('12:00.00');
explain
SELECT a, COUNT(*) FROM t GROUP BY a LIMIT 2;
SELECT a, COUNT(*) FROM t GROUP BY a LIMIT 2;
SELECT * FROM t;

DROP TABLE t;

--echo # Type_handler_date_common

--echo ## datetime, date
CREATE TABLE t (a datetime, b date as (a), key(b));
INSERT IGNORE INTO t (a) VALUES ('2026-01-01 12:00'),('2026-01-01 16:00');
explain
SELECT a, COUNT(*) FROM t GROUP BY a;
SELECT a, COUNT(*) FROM t GROUP BY a;
SELECT * FROM t;

DROP TABLE t;

--echo ## date +/- 1, date
CREATE TABLE t (a date, b date as (a + 1), c date as (a - 1), key(b), key(c));
INSERT IGNORE INTO t (a) VALUES ('2026-01-01'),('9999-12-31'),('0000-00-00');
explain
SELECT a + 1, COUNT(*) FROM t GROUP BY a + 1;
SELECT a + 1, COUNT(*) FROM t GROUP BY a + 1;
explain
SELECT a - 1, COUNT(*) FROM t GROUP BY a - 1;
SELECT a - 1, COUNT(*) FROM t GROUP BY a - 1;
SELECT a, a + 1, b, a - 1, c FROM t;

DROP TABLE t;

--echo ## date < date
CREATE TABLE t (a date, b date as (a), key(b));
INSERT IGNORE INTO t (a) VALUES ('2026-01-01'),('9999-12-31'),('0000-00-00');
explain
SELECT a, COUNT(*) FROM t GROUP BY a LIMIT 2;
SELECT a, COUNT(*) FROM t GROUP BY a LIMIT 2;
SELECT * FROM t;

DROP TABLE t;

