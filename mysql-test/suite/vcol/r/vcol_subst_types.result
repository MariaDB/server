# Type_handler_geometry
## varchar, point
CREATE TABLE t (a varchar(20), b point as (a), key(b));
INSERT IGNORE INTO t (a) VALUES ('point(0,0)'),('point(1,0)'),('point(0,0)');
ERROR 22003: Cannot get geometry object from data you send to the GEOMETRY field
DROP TABLE t;
## point, polygon
CREATE TABLE t (a point, b polygon as (a), key(b));
Warnings:
Note	1071	Specified key was too long; max key length is 1000 bytes
INSERT IGNORE INTO t (a) VALUES (point(0,0)),(point(1,0)),(point(0,0));
ERROR 22007: Incorrect POLYGON value: 'POINT(0 0)' for column `test`.`t`.`b` at row 1
DROP TABLE t;
## boundary(linestring), multipoint
## the type of boundary(linestring) is geometry
CREATE TABLE t (a linestring, b multipoint as (boundary(a)), key(b));
Warnings:
Note	1071	Specified key was too long; max key length is 1000 bytes
INSERT IGNORE INTO t (a) VALUES
(LineStringFromText('LINESTRING(10 10,20 10,10 10)')),
(LineStringFromText('LINESTRING(10 10,5 10,10 10)')),
(LineStringFromText('LINESTRING(10 10,20 10,5 10)'));
explain
SELECT ST_AsWKT(a), COUNT(*) FROM t GROUP BY boundary(a);
id	select_type	table	type	possible_keys	key	key_len	ref	rows	Extra
1	SIMPLE	t	ALL	NULL	NULL	NULL	NULL	3	Using temporary; Using filesort
Warnings:
Note	1105	Cannot substitute virtual column expression st_boundary(`t`.`a`) -> b due to failed supertype check
SELECT ST_AsWKT(a), COUNT(*) FROM t GROUP BY boundary(a);
ST_AsWKT(a)	COUNT(*)
LINESTRING(10 10,20 10,5 10)	1
LINESTRING(10 10,20 10,10 10)	2
SELECT ST_AsWKT(a), ST_AsWKT(boundary(a)), ST_AsWKT(b) FROM t;
ST_AsWKT(a)	ST_AsWKT(boundary(a))	ST_AsWKT(b)
LINESTRING(10 10,20 10,10 10)	MULTIPOINT(10 10,10 10)	MULTIPOINT(10 10,10 10)
LINESTRING(10 10,5 10,10 10)	MULTIPOINT(10 10,10 10)	MULTIPOINT(10 10,10 10)
LINESTRING(10 10,20 10,5 10)	MULTIPOINT(10 10,5 10)	MULTIPOINT(10 10,5 10)
DROP TABLE t;
