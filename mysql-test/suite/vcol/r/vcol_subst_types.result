#
# MDEV-38752 Wrong result upon GROUP BY on a table with indexed virtual column after INSERT IGNORE
#
# Type_handler_real_result
## float(4,2), double(4,2)
CREATE TABLE t (a float(4,2), b double(4,2) AS (a), KEY(b));
INSERT IGNORE INTO t (a) VALUES (-33.11),(-33.12),(33.13);
explain
SELECT a, COUNT(*) FROM t GROUP BY a;
id	select_type	table	type	possible_keys	key	key_len	ref	rows	Extra
1	SIMPLE	t	ALL	NULL	NULL	NULL	NULL	3	Using temporary; Using filesort
Warnings:
Note	1105	Cannot substitute virtual column expression `t`.`a` -> b due to failed supertype check
SELECT a, COUNT(*) FROM t GROUP BY a;
a	COUNT(*)
-33.12	1
-33.11	1
33.13	1
SELECT * FROM t;
a	b
-33.11	-33.11
-33.12	-33.12
33.13	33.13
DROP TABLE t;
## float(4,2), float(5,3) unsigned
CREATE TABLE t (a float(4,2), b float(5,3) unsigned AS (a), KEY(b));
INSERT IGNORE INTO t (a) VALUES (-33.11),(-33.12),(0.00);
Warnings:
Warning	1264	Out of range value for column 'b' at row 1
Warning	1264	Out of range value for column 'b' at row 2
explain
SELECT a, COUNT(*) FROM t GROUP BY a;
id	select_type	table	type	possible_keys	key	key_len	ref	rows	Extra
1	SIMPLE	t	ALL	NULL	NULL	NULL	NULL	3	Using temporary; Using filesort
Warnings:
Note	1105	Cannot substitute virtual column expression `t`.`a` -> b due to failed supertype check
SELECT a, COUNT(*) FROM t GROUP BY a;
a	COUNT(*)
-33.12	1
-33.11	1
0.00	1
SELECT * FROM t;
a	b
-33.11	0.000
-33.12	0.000
0.00	0.000
DROP TABLE t;
## float(5,3), float(4,2)
CREATE TABLE t (a float(5,3), b float(4,2) AS (a), KEY(b));
INSERT IGNORE INTO t (a) VALUES (33.111),(33.112);
explain
SELECT a, COUNT(*) FROM t GROUP BY a;
id	select_type	table	type	possible_keys	key	key_len	ref	rows	Extra
1	SIMPLE	t	ALL	NULL	NULL	NULL	NULL	2	Using temporary; Using filesort
Warnings:
Note	1105	Cannot substitute virtual column expression `t`.`a` -> b due to failed supertype check
SELECT a, COUNT(*) FROM t GROUP BY a;
