--source include/have_debug.inc

if ($HA_PARQUET_SO) {
  --replace_regex /\.dll/.so/
  eval INSTALL PLUGIN parquet SONAME '$HA_PARQUET_SO';
}

DROP TABLE IF EXISTS t1;

SET @old_debug_dbug = @@session.debug_dbug;
SET SESSION debug_dbug = '+d,parquet_flush_threshold_one';

CREATE TABLE t1(id INT) ENGINE=PARQUET;
INSERT INTO t1 VALUES (1), (2), (3);
SELECT COUNT(*) AS rows_written, SUM(id) AS id_sum FROM t1;

SET SESSION debug_dbug = @old_debug_dbug;

DROP TABLE t1;

let $MYSQLD_DATADIR= `SELECT @@datadir`;
--remove_file $MYSQLD_DATADIR/test/t1.parquet
--remove_file $MYSQLD_DATADIR/test/t1.parquet.meta
--remove_file $MYSQLD_DATADIR/test/duckdb_helper.duckdb
--remove_files_wildcard $MYSQLD_DATADIR/test t1.stage_*.parquet

if ($HA_PARQUET_SO) {
  SELECT 1;
  UNINSTALL PLUGIN parquet;
}
