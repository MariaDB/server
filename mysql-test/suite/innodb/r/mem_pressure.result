#
# MDEV-24670 avoid OOM by linux kernel co-operative memory management
#
set @save_dbug=@@debug_dbug;
set @save_limit=@@GLOBAL.innodb_limit_optimistic_insert_debug;
set GLOBAL innodb_max_purge_lag_wait=0;
SET @innodb_buffer_pool_size= @@GLOBAL.innodb_buffer_pool_size;
SET GLOBAL innodb_buffer_pool_size=2*@@innodb_buffer_pool_size;
SET GLOBAL innodb_buffer_pool_size_min=2*@@innodb_buffer_pool_size;
Warnings:
Warning	1292	Truncated incorrect innodb_buffer_pool_size_min value: '33554432'
CREATE TABLE t1 (a INT PRIMARY KEY) ENGINE=InnoDB;
SET GLOBAL innodb_limit_optimistic_insert_debug=2;
SET STATEMENT unique_checks=0, foreign_key_checks=0 FOR
INSERT INTO t1 SELECT * FROM seq_1_to_1000;
SET GLOBAL innodb_limit_optimistic_insert_debug=@save_limit;
DROP TABLE t1;
SET STATEMENT debug_dbug="d,trigger_garbage_collection" FOR
SET GLOBAL innodb_buffer_pool_size=2*@@innodb_buffer_pool_size;
Warnings:
Warning	1292	Truncated incorrect innodb_buffer_pool_size value: '33554432'
FOUND 1 /Memory pressure event disregarded/ in mysqld.1.err
SET GLOBAL innodb_buffer_pool_size_min=@innodb_buffer_pool_size;
SET STATEMENT debug_dbug="d,trigger_garbage_collection" FOR
SET GLOBAL innodb_buffer_pool_size=2*@@innodb_buffer_pool_size;
Warnings:
Warning	1292	Truncated incorrect innodb_buffer_pool_size value: '33554432'
select @@global.innodb_buffer_pool_size < 2*@@innodb_buffer_pool_size;
@@global.innodb_buffer_pool_size < 2*@@innodb_buffer_pool_size
1
FOUND 1 /InnoDB: Memory pressure event shrunk/ in mysqld.1.err
set debug_dbug=@save_dbug;
SET GLOBAL innodb_buffer_pool_size= @innodb_buffer_pool_size;
# End of 10.11 tests
