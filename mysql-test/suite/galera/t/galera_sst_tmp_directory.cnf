!include ../galera_2nodes.cnf

[mysqld]
wsrep_sst_method=mariabackup
wsrep_sst_auth="root:"
wsrep_debug=1
innodb_fast_shutdown=0
innodb_undo_tablespaces=0

[mysqld.1]
wsrep_provider_options='pc.ignore_sb=true;base_port=@mysqld.1.#galera_port'

[mysqld.2]
wsrep_provider_options='pc.ignore_sb=true;base_port=@mysqld.2.#galera_port'
wsrep_sst_tmp_dir=@ENV.MYSQLTEST_VARDIR/tmp

[sst]
transferfmt=@ENV.MTR_GALERA_TFMT
streamfmt=mbstream
