# Shutdown and restart work ok
CREATE TABLE t1 (a INT);
CREATE TRIGGER t1_bu
BEFORE UPDATE ON t1
FOR EACH ROW
BEGIN
SET NEW = OLD;
END;|
SHOW TRIGGERS;
Trigger	Event	Table	Statement	Timing	Created	sql_mode	Definer	character_set_client	collation_connection	Database Collation
t1_bu	UPDATE	t1	BEGIN
SET NEW = OLD;
END	BEFORE	#	STRICT_TRANS_TABLES,ERROR_FOR_DIVISION_BY_ZERO,NO_AUTO_CREATE_USER,NO_ENGINE_SUBSTITUTION	root@localhost	latin1	latin1_swedish_ci	utf8mb4_uca1400_ai_ci
# restart
SHOW TRIGGERS;
Trigger	Event	Table	Statement	Timing	Created	sql_mode	Definer	character_set_client	collation_connection	Database Collation
t1_bu	UPDATE	t1	BEGIN
SET NEW = OLD;
END	BEFORE	#	STRICT_TRANS_TABLES,ERROR_FOR_DIVISION_BY_ZERO,NO_AUTO_CREATE_USER,NO_ENGINE_SUBSTITUTION	root@localhost	latin1	latin1_swedish_ci	utf8mb4_uca1400_ai_ci
DROP TRIGGER t1_bu;
DROP TABLE t1;
# No unnecessary error emitted
CREATE TABLE t1 (a INT);
CREATE TRIGGER t1_bu
BEFORE UPDATE ON t1
FOR EACH ROW
BEGIN
DECLARE r ROW TYPE OF t1 DEFAULT (SELECT * FROM t1 WHERE a=1);
SET NEW = r;
END;|
INSERT INTO t1 VALUES (1),(3);
UPDATE t1 SET a = 10 WHERE a = 3;
SELECT * FROM t1;
a
1
1
DROP TRIGGER t1_bu;
DROP TABLE t1;
#
# Stored procedure variable scoping
#
DROP PROCEDURE IF EXISTS scope;
Warnings:
Note	1305	PROCEDURE test.scope does not exist
CREATE PROCEDURE scope(a INT, b FLOAT)
BEGIN
DECLARE b INT DEFAULT 100;
DECLARE c FLOAT;
SET c = 5.5;
BEGIN
DECLARE c INT;
SET c = 10;
SELECT a, b, c;
END;
SELECT a, b, c;
END|
CALL scope(1, 2);
a	b	c
1	100	10
a	b	c
1	100	5.5
DROP PROCEDURE scope;
