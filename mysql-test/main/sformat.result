select sformat("string test");
sformat("string test")
string test
select sformat('string test');
sformat('string test')
string test
select sformat('string test') from dual;
sformat('string test')
string test
select sformat('what {} is {}?', 'time', 'it');
sformat('what {} is {}?', 'time', 'it')
what {} is {}?timeit
