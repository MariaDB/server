SET sql_mode = 'ORACLE';
SELECT TO_DATE('2002 AD', 'YYYY - AD') FROM DUAL;
TO_DATE('2002 AD', 'YYYY - AD')
2002-03-15 00:00:00
SELECT TO_DATE('2002 - AD', 'YYYY AD') FROM DUAL;
TO_DATE('2002 - AD', 'YYYY AD')
2002-03-15 00:00:00
SELECT TO_DATE('2002 - AD', 'YYYY-AD') FROM DUAL;
TO_DATE('2002 - AD', 'YYYY-AD')
2002-03-15 00:00:00
