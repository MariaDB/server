{"c": 3}
{"c": 1}
{"c": 2}
Test unquoting operator
INSERT INTO t1_mysql(f1) VALUES
('{"t":"a"}'),
('{"t":"b"}'),
('{"t":"c"}');
Returned values should be quoted
SELECT f1->"$.t" FROM t1_mysql WHERE f1->"$.t" <> 'NULL' order by autopk;
f1->"$.t"
"a"
"b"
"c"
Returned values should be unquoted
SELECT f1->>"$.t" FROM t1_mysql WHERE f1->>"$.t" <> 'NULL' order by autopk;
f1->>"$.t"
a
b
c
