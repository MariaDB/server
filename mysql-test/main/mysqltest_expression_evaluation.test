# ----------------------------------------------------------------------------

--echo # SUBSTR function

let $str = "hello";

let $from = -7;
while ($from <= 7)
{
  let $to = -7;
  while ($to <= 7)
  {
    let $result = $(substr($str, $from, $to));
    --echo substr("hello", $from, $to) -> "$result"
    --inc $to
  }
  --inc $from
}

