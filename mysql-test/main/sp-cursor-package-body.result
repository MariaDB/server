/
CREATE PACKAGE BODY pkg
DECLARE cur CURSOR FOR SELECT 1 AS c FROM DUAL;
DECLARE vc0 INT;
DECLARE vc1 INT;
FUNCTION f1() RETURNS INT
BEGIN
OPEN cur;
FETCH cur INTO vc1;
RETURN vc0 + vc1;
END;
-- initialization
BEGIN
DECLARE vc2 INT;
OPEN cur;
FETCH cur INTO vc2;
CLOSE cur;
SET vc0= vc2;
END;
END;
