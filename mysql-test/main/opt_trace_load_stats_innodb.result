drop table t1;
#
# run a range query on a table, then truncate the table,
# and rerun the same query by setting the context from previous query
#
create table t1 (c1 int, c2 int, index(c1)) engine=innodb;
insert into t1 select seq, seq from seq_1_to_10000;
analyze table t1;
