set optimizer_record_context=ON;
set optimizer_trace=1;
create database db1;
use db1;
create table t1 (
c1 int,
c2 int,
index(c1),
index(c2)
) ENGINE=InnoDB;
insert into t1 select seq, seq from seq_1_to_1000;
analyze table t1;
Table	Op	Msg_type	Msg_text
db1.t1	analyze	status	Engine-independent statistics collected
db1.t1	analyze	status	OK
#
# run a query with two different ranges on the same index
# record stats and re-run same query
#
set optimizer_replay_context="";
explain format=json select * from t1 a, t1 b where a.c1 < 3 and b.c1 < 333 and a.c2 < 3 and b.c2 < 333;
EXPLAIN
{
  "query_block": {
    "select_id": 1,
    "cost": 0.191374711,
    "nested_loop": [
      {
        "table": {
          "table_name": "a",
          "access_type": "range",
          "possible_keys": ["c1", "c2"],
          "key": "c1",
          "key_length": "5",
          "used_key_parts": ["c1"],
          "rowid_filter": {
            "range": {
              "key": "c2",
              "used_key_parts": ["c2"]
            },
            "rows": 2,
            "selectivity_pct": 0.2
          },
          "loops": 1,
          "rows": 2,
          "cost": 0.004658583,
          "filtered": 0.200000003,
          "index_condition": "a.c1 < 3",
          "attached_condition": "a.c2 < 3"
        }
      },
      {
        "block-nl-join": {
          "table": {
            "table_name": "b",
            "access_type": "ALL",
            "possible_keys": ["c1", "c2"],
            "loops": 1,
            "rows": 1000,
            "cost": 0.186716128,
            "filtered": 11.0223999,
            "attached_condition": "b.c1 < 333 and b.c2 < 333"
          },
          "buffer_type": "flat",
          "buffer_size": "119",
          "join_type": "BNL"
        }
      }
    ]
  }
}
