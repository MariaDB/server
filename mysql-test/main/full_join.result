# FULL JOIN referencing a missing table must error cleanly.
select * from t1, t2 full join t_not_exist on t2.c=t_not_exist.e and t_not_exist.f=t1.a;
ERROR 42S02: Table 'test.t_not_exist' doesn't exist
select * from t1, t2 full outer join t_not_exist on t2.c=t_not_exist.e and t_not_exist.f=t1.a;
ERROR 42S02: Table 'test.t_not_exist' doesn't exist
select * from t1, t2 natural full join t_not_exist;
ERROR 42S02: Table 'test.t_not_exist' doesn't exist
select * from t1, t2 natural full outer join t_not_exist;
ERROR 42S02: Table 'test.t_not_exist' doesn't exist
# FULL JOIN where one operand is a derived table (on the left).
select * from (select * from t1) dt natural full join t2;
a
1
2
3
