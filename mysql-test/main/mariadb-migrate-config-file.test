invalid=true
alter_algorithm=invalid
key_buffer_size=20M
invalid_option
EOF
--exec echo "!include $MYSQLTEST_VARDIR/tmp/tmp2.cnf" >> $MYSQLTEST_VARDIR/tmp/tmp1.cnf
--exec echo "log-bin" >> $MYSQLTEST_VARDIR/tmp/tmp1.cnf

--replace_result $MYSQLTEST_VARDIR MYSQLTEST_VARDIR
--cat_file $MYSQLTEST_VARDIR/tmp/tmp1.cnf

--write_file $MYSQLTEST_VARDIR/tmp/tmp2.cnf
# Include file start

[mysqld]
log-bin=1
log_error_verbosity   = 3
EOF
--cat_file $MYSQLTEST_VARDIR/tmp/tmp2.cnf
--replace_result $MYSQLTEST_VARDIR MYSQLTEST_VARDIR
--exec $MARIADB_MIGRATE_CONFIG_FILE --defaults-file=$MYSQLTEST_VARDIR/tmp/tmp1.cnf --mariadbd=$MYSQLD --update --verify --edit=last

--echo # Changed files
