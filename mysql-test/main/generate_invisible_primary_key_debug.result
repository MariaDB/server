t0	1	invisible	1	invisible	A	NULL	NULL	NULL	YES	BTREE			NO
SET sql_generate_invisible_primary_key=ON;
CREATE TABLE t1 (c1 INT, c2 INT);
SHOW INDEX FROM t1;
