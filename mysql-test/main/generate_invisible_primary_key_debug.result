INSERT INTO t1 VALUES (4, 0);
SELECT _rowid, t1.* FROM t1;
_rowid	c1	c2
1	3	0
2	4	0
ALTER TABLE t1 ADD c3 INT;
SHOW INDEX FROM t1;
