set store_ddls_in_optimizer_trace=ON;

show variables like 'store_ddls_in_optimizer_trace';
Variable_name	Value
store_ddls_in_optimizer_trace	ON

set store_ddls_in_optimizer_trace=OFF;

show variables like 'store_ddls_in_optimizer_trace';
Variable_name	Value
store_ddls_in_optimizer_trace	OFF

create table t1 (a int, b int);
insert into t1 values (1,2),(2,3);

create table t2 (a int);
insert into t2 values (1),(2);

create view view1 as (select t1.a as a, t1.b as b, t2.a as c from (t1 join t2) where t1.a = t2.a);

optimizer_trace=OFF, and store_ddls_in_optimizer_trace=OFF
there should be no trace

set optimizer_trace=0;
set store_ddls_in_optimizer_trace=OFF;

select * from t1 where t1.a = 3;
a	b

select json_detailed(json_extract(trace, '$**.list_ddls'))
from information_schema.optimizer_trace;
json_detailed(json_extract(trace, '$**.list_ddls'))

optimizer_trace=OFF, and store_ddls_in_optimizer_trace=ON
there should be no trace here as well

set store_ddls_in_optimizer_trace=ON;

select * from t1 where t1.a = 3;
a	b

select json_detailed(json_extract(trace, '$**.list_ddls'))
from information_schema.optimizer_trace;
json_detailed(json_extract(trace, '$**.list_ddls'))

optimizer_trace=ON, and store_ddls_in_optimizer_trace=OFF
trace result should be empty

set optimizer_trace=1;
set store_ddls_in_optimizer_trace=OFF;

select * from t1 where t1.a = 3;
a	b

select json_detailed(json_extract(trace, '$**.list_ddls'))
from information_schema.optimizer_trace;
json_detailed(json_extract(trace, '$**.list_ddls'))
NULL

optimizer_trace=ON, and store_ddls_in_optimizer_trace=ON
trace result should have 1 ddl statement

set optimizer_trace=1;
set store_ddls_in_optimizer_trace=ON;

select * from t1 where t1.a = 3;
