connection default;
BACKUP STAGE START;
connect  con1,localhost,root,,test;
BACKUP SERVER TO '<MYSQLTEST_VARDIR>/some_directory';
connection default;
SET @con1_id = <con1_id>;
SELECT COMMAND, STATE, INFO FROM INFORMATION_SCHEMA.PROCESSLIST WHERE ID = @con1_id;
