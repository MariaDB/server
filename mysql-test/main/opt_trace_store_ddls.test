#--source include/not_embedded.inc
#--source include/have_sequence.inc
--disable_ps_protocol

set store_ddls_in_optimizer_trace=ON;
--echo 
show variables like 'store_ddls_in_optimizer_trace';

--echo 
set store_ddls_in_optimizer_trace=OFF;
--echo 
show variables like 'store_ddls_in_optimizer_trace';

--echo 
create table t1 (a int, b int);
insert into t1 values (1,2),(2,3);

--echo 
create table t2 (a int);
insert into t2 values (1),(2);

--echo 
create view view1 as (select t1.a as a, t1.b as b, t2.a as c from (t1 join t2) where t1.a = t2.a);

--echo 
--echo optimizer_trace=OFF, and store_ddls_in_optimizer_trace=OFF
--echo there should be no trace
--echo 
set optimizer_trace=0;
set store_ddls_in_optimizer_trace=OFF;
--echo 
select * from t1 where t1.a = 3;
--echo 
select json_detailed(json_extract(trace, '$**.list_ddls'))
    from information_schema.optimizer_trace;

--echo
--echo optimizer_trace=OFF, and store_ddls_in_optimizer_trace=ON
--echo there should be no trace here as well
--echo

set store_ddls_in_optimizer_trace=ON;
--echo 
select * from t1 where t1.a = 3;
--echo 
select json_detailed(json_extract(trace, '$**.list_ddls'))
    from information_schema.optimizer_trace;

--echo 
--echo optimizer_trace=ON, and store_ddls_in_optimizer_trace=OFF
--echo trace result should be empty
--echo 
set optimizer_trace=1;
set store_ddls_in_optimizer_trace=OFF;
--echo 
select * from t1 where t1.a = 3;
--echo 
select json_detailed(json_extract(trace, '$**.list_ddls'))
    from information_schema.optimizer_trace;

--echo 
--echo optimizer_trace=ON, and store_ddls_in_optimizer_trace=ON
--echo trace result should have 1 ddl statement
--echo 
set optimizer_trace=1;
set store_ddls_in_optimizer_trace=ON;
--echo 
select * from t1 where t1.a = 3;
--echo 
select json_detailed(json_extract(trace, '$**.list_ddls'))
    from information_schema.optimizer_trace;

--echo 
--echo optimizer_trace=ON, and store_ddls_in_optimizer_trace=ON
--echo trace result should have 3 ddl statements
--echo 
--echo
set optimizer_trace=1;
set store_ddls_in_optimizer_trace=ON;
select * from view1 where view1.a = 3;
--echo 
select json_detailed(json_extract(trace, '$**.list_ddls'))
    from information_schema.optimizer_trace;

drop view view1;
drop table t1;
drop table t2;