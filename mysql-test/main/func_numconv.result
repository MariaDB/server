to_number('1.2E+1-',  '99EEEES')
-12
SELECT to_number('1.2E+1+',  '99EEEES');
to_number('1.2E+1+',  '99EEEES')
12
SELECT to_number('1.2E+1-',  '99EEEEMI');
to_number('1.2E+1-',  '99EEEEMI')
-12
SELECT to_number('1.2E+1 ',  '99EEEEMI');
to_number('1.2E+1 ',  '99EEEEMI')
12
SELECT to_number('<1.2E+1>', '99EEEEPR');
to_number('<1.2E+1>', '99EEEEPR')
-12
SELECT to_number(' 1.2E+1 ', '99EEEEPR');
to_number(' 1.2E+1 ', '99EEEEPR')
12
