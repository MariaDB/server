#
# MDEV-10556 Assertion `0' failed in virtual void Item_sum_field::set_result_field(Field*)
#
CREATE TABLE t1 (i INT) ENGINE=InnoDB;
SELECT DISTINCT STDDEV(1) FROM t1 GROUP BY i ORDER BY BENCHMARK(0, BIT_XOR(i));
STDDEV(1)
DROP TABLE t1;
# End of 10.1 tests
#
# MDEV-39131 Wrong Results in Identical Queries Involving Grouping and Bitwise NOT (~)
#
create table t0(c0 double) engine=myisam ;
select count(*), ~0 from t0;
count(*)	~0
0	18446744073709551615
alter table t0 engine=innodb;
select count(*), ~0 from t0;
count(*)	~0
0	18446744073709551615
drop table t0;
# End of 10.11 tests
