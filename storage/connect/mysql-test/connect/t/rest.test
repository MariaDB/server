--source rest.inc

let $MYSQLD_DATADIR= `select @@datadir`;

--echo #
--echo # Testing REST query
--echo #
CREATE TABLE t1
ENGINE=CONNECT DATA_CHARSET=utf8 TABLE_TYPE=JSON FILE_NAME='users.json'
HTTP='http://jsonplaceholder.typicode.com/users';
SELECT * FROM t1;
DROP TABLE t1;
--remove_file $MYSQLD_DATADIR/test/users.json

--echo #
--echo # MDEV-39289 CONNECT REST support on Windows doesn't escape the url
--echo #
--error ER_UNKNOWN_ERROR,ER_GET_ERRNO
CREATE TABLE t1
ENGINE=CONNECT DATA_CHARSET=utf8 TABLE_TYPE=JSON FILE_NAME='users.json'
HTTP='http://jsonplaceholder.typicode.com/users" "-Dhead.log';

--echo # End of 10.6 tests
